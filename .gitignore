# This repo holds a RECIPE, never state or secrets.
#
# NOTE: do not add a bare `plugins/` or `cache/` rule here. This repo IS a
# marketplace, so `plugins/my-stack/` is real tracked content -- a bare
# `plugins/` rule silently drops the bundle manifest and the marketplace
# still clones fine, only to fail at install with "Source path does not
# exist". Scope anything ~/.claude-shaped under dotfiles/ instead.

# Live OAuth tokens for the Claude account and every connected MCP server.
.credentials.json
.claude.json

# Conversation data.
history.jsonl
projects/
sessions/
session-env/
shell-snapshots/
file-history/
backups/

# Machine-local: absolute C:\Users\... paths, SSH key locations, server IPs,
# and per-project permission grants. Not portable, often sensitive.
settings.local.json

# Regenerable state, if any of it ever gets copied into dotfiles/.
# ~/.claude/plugins alone is ~537 MB.
dotfiles/plugins/
dotfiles/cache/
dotfiles/mcp-needs-auth-cache.json
dotfiles/.last-update-result.json
dotfiles/.last-cleanup

# The skills CLI's real content. Re-fetched from GitHub by bootstrap; the
# junctions in ~/.claude/skills point at absolute paths and never travel.
.agents/
